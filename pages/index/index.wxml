<view class="container">
  <view class="header">
    <view class="title">无人机检测系统</view>
    <view class="subtitle">SDR无线电信号监测</view>
  </view>

  <view class="stats">
    <view class="stat-item">
      <view class="stat-value">{{stats.totalLocations}}</view>
      <view class="stat-label">监测点</view>
    </view>
    <view class="stat-item">
      <view class="stat-value">{{stats.activeAlerts}}</view>
      <view class="stat-label">待处理警报</view>
    </view>
    <view class="stat-item">
      <view class="stat-value">{{stats.todayDetections}}</view>
      <view class="stat-label">今日检测</view>
    </view>
  </view>

  <view class="menu">
    <view class="menu-item" bindtap="navigateToAlerts">
      <view class="menu-icon alert-icon"></view>
      <view class="menu-text">
        <view class="menu-title">警报列表</view>
        <view class="menu-desc">查看未处理的警报</view>
      </view>
    </view>
    <view class="menu-item" bindtap="navigateToRecords">
      <view class="menu-icon record-icon"></view>
      <view class="menu-text">
        <view class="menu-title">检测记录</view>
        <view class="menu-desc">查看历史检测数据</view>
      </view>
    </view>
    <view class="menu-item" bindtap="navigateToLocations">
      <view class="menu-icon location-icon"></view>
      <view class="menu-text">
        <view class="menu-title">监测点管理</view>
        <view class="menu-desc">管理SDR监测设备</view>
      </view>
    </view>
    <view class="menu-item" bindtap="navigateToAdmin">
      <view class="menu-icon admin-icon"></view>
      <view class="menu-text">
        <view class="menu-title">系统管理</view>
        <view class="menu-desc">管理员设置</view>
      </view>
    </view>
  </view>

  <view class="recent-alerts" wx:if="{{recentAlerts.length > 0}}">
    <view class="section-title">最近警报</view>
    <view wx:for="{{recentAlerts}}" wx:key="_id" class="alert-item">
      <view class="alert-location">{{item.location_name}}</view>
      <view class="alert-time">{{item.formatted_time}}</view>
    </view>
  </view>
</view>
