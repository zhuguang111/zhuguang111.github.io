.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  padding: 20rpx 30rpx;
}

.unread-badge {
  display: inline-block;
  background-color: #ff4d4f;
  color: #fff;
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
}

.tabs {
  display: flex;
  background-color: #fff;
  border-bottom: 1rpx solid #eee;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 30rpx;
  font-size: 28rpx;
  color: #666;
}

.tab.active {
  color: #ff4d4f;
  border-bottom: 4rpx solid #ff4d4f;
}

.loading, .empty {
  text-align: center;
  padding: 60rpx;
  color: #999;
  font-size: 28rpx;
}

.alert-list {
  padding: 20rpx;
}

.alert-item {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.alert-item.unread {
  border-left: 8rpx solid #ff4d4f;
}

.alert-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.alert-icon {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: #ff4d4f;
  margin-right: 15rpx;
}

.alert-item.unread .alert-icon {
  animation: pulse 1s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.alert-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.alert-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.alert-status.pending {
  background-color: #fff7e6;
  color: #fa8c16;
}

.alert-status.handled {
  background-color: #f6ffed;
  color: #52c41a;
}

.alert-body {
  margin-bottom: 20rpx;
}

.alert-info {
  display: flex;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.alert-info .label {
  width: 160rpx;
}

.alert-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
}

.handle-btn {
  background-color: #ff4d4f;
  color: #fff;
}

.ignore-btn {
  background-color: #f0f0f0;
  color: #666;
}

.load-more {
  text-align: center;
  padding: 30rpx;
  color: #ff4d4f;
  font-size: 26rpx;
}
