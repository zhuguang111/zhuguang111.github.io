.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.login-container {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.login-box {
  width: 100%;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  text-align: center;
  margin-bottom: 60rpx;
}

.input {
  width: 100%;
  height: 90rpx;
  background: #f7f7f7;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  margin-bottom: 30rpx;
}

.login-btn {
  width: 100%;
  height: 90rpx;
  background: #ff4d4f;
  color: #ffffff;
  border-radius: 45rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-top: 20rpx;
}

.header {
  background: #ff4d4f;
  padding: 30rpx 40rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.welcome {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
}

.logout-btn {
  color: #ffffff;
  font-size: 28rpx;
}

.menu {
  padding: 30rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
}

.menu-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  margin-right: 20rpx;
}

.alert-icon {
  background: linear-gradient(135deg, #ff4d4f, #ff7a45);
}

.record-icon {
  background: linear-gradient(135deg, #1890ff, #36aafd);
}

.location-icon {
  background: linear-gradient(135deg, #52c41a, #73d13d);
}

.menu-text {
  flex: 1;
}

.menu-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.menu-desc {
  font-size: 24rpx;
  color: #999;
}
