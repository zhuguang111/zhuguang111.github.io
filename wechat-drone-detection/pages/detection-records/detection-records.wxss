.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.filter-bar {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx;
  background-color: #fff;
}

.filter-item {
  flex: 1;
  background-color: #f0f0f0;
  padding: 20rpx;
  border-radius: 10rpx;
  font-size: 26rpx;
  text-align: center;
}

.tabs {
  display: flex;
  background-color: #fff;
  border-bottom: 1rpx solid #eee;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 25rpx;
  font-size: 28rpx;
  color: #666;
}

.tab.active {
  color: #ff4d4f;
  border-bottom: 4rpx solid #ff4d4f;
}

.loading, .empty {
  text-align: center;
  padding: 60rpx;
  color: #999;
}

.record-list {
  padding: 20rpx;
}

.record-item {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 25rpx;
  margin-bottom: 15rpx;
}

.record-item.drone {
  border-left: 8rpx solid #ff4d4f;
}

.record-header {
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
}

.location {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.drone-tag {
  background-color: #ff4d4f;
  color: #fff;
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  border-radius: 20rpx;
}

.record-body .info {
  display: flex;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.info .label {
  width: 150rpx;
}

.info .value.strong {
  color: #ff4d4f;
  font-weight: bold;
}

.load-more {
  text-align: center;
  padding: 25rpx;
  color: #ff4d4f;
}
