.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  background-color: #1890ff;
  padding: 30rpx;
  color: #fff;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.date-picker {
  display: inline-block;
  background-color: rgba(255, 255, 255, 0.2);
  padding: 15rpx 30rpx;
  border-radius: 8rpx;
}

.picker {
  color: #fff;
  font-size: 28rpx;
}

.tabs {
  display: flex;
  background-color: #fff;
  border-bottom: 1rpx solid #eee;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 30rpx;
  font-size: 28rpx;
  color: #666;
}

.tab.active {
  color: #1890ff;
  border-bottom: 4rpx solid #1890ff;
}

.filter {
  background-color: #fff;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #eee;
}

.filter-item {
  display: inline-block;
  background-color: #f0f0f0;
  padding: 15rpx 30rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #333;
}

.content {
  padding: 20rpx;
}

.loading, .empty {
  text-align: center;
  padding: 60rpx;
  color: #999;
  font-size: 28rpx;
}

.record-list, .statistics-list {
  background-color: #fff;
  border-radius: 12rpx;
  overflow: hidden;
}

.record-item, .stat-item {
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-item:last-child, .stat-item:last-child {
  border-bottom: none;
}

.record-header, .stat-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.location {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.time, .hour {
  font-size: 24rpx;
  color: #999;
}

.record-body, .stat-body {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.person, .person-id {
  font-size: 26rpx;
  color: #666;
}

.person-id {
  font-size: 24rpx;
  color: #999;
}

.count {
  font-size: 28rpx;
  color: #1890ff;
  font-weight: bold;
}

.record-image {
  margin-top: 20rpx;
}

.record-image image {
  width: 150rpx;
  height: 150rpx;
  border-radius: 8rpx;
}

.load-more {
  text-align: center;
  padding: 30rpx;
  color: #1890ff;
  font-size: 26rpx;
}
